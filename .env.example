# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ENABLE_CRONS=true

# Application environment — controls frontend redirect target after OAuth
# Values: staging | production
APP_ENV=staging

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5434/padelpoint_db
DB_SYNC=false
DB_LOG=false

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ─── Apple Sign In ────────────────────────────────────────────────────────────
# Create credentials at https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=com.example.service
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
# Paste the full PEM contents of the .p8 key (replace newlines with \n for Railway)
APPLE_PRIVATE_KEY=
# Staging:    https://padelpoint-staging.up.railway.app/auth/apple/callback
# Production: https://padelpoint-production.up.railway.app/auth/apple/callback
APPLE_CALLBACK_URL=https://padelpoint-staging.up.railway.app/auth/apple/callback

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Staging:    https://padelpoint-staging.up.railway.app/auth/google/callback
# Production: https://padelpoint-production.up.railway.app/auth/google/callback
GOOGLE_CALLBACK_URL=https://padelpoint-staging.up.railway.app/auth/google/callback

# ─── Frontend URLs (used for post-OAuth redirect) ────────────────────────────
FRONT_STAGING_URL=https://staging-padel-point-front.vercel.app
FRONT_PROD_URL=https://padel-point-front.vercel.app

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Media ───────────────────────────────────────────────────────────────────
MEDIA_ALLOWED_FORMATS=jpg,jpeg,png,webp
MEDIA_MAX_BYTES=5000000

# ─── MercadoPago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_CURRENCY=ARS

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=PadelPoint <noreply@padelpoint.app>
APP_URL=http://localhost:3000
EMAIL_ENABLED=true
EMAIL_LOG_ONLY=false

# ─── Misc ────────────────────────────────────────────────────────────────────
DISPUTE_WINDOW_HOURS=48
ADMIN_BOOTSTRAP_KEY=
